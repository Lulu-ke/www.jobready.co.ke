generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
}

model Employer {
  id            String        @id @default(cuid())
  companyName   String
  slug          String        @unique
  email         String        @unique
  phone         String?
  logoUrl       String?
  description   String?       @db.Text
  orgType       OrgType       @default(PRIVATE)
  createdAt     DateTime      @default(now())
  jobs          Job[]
  opportunities Opportunity[]
  sponsoredAds  SponsoredAd[]
  user          User?
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String
  color       String
  jobCount    Int      @default(0)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]
}

model Job {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  description     String           @db.Text
  howToApply      String           @db.Text
  location        String
  county          String
  type            String           @default("Full-Time")
  experienceLevel ExperienceLevel  @default(mid)
  categoryId      String?
  salaryMin       Int?
  salaryMax       Int?
  currency        String           @default("KSh")
  isRemote        Boolean          @default(false)
  isFeatured      Boolean          @default(false)
  isActive        Boolean          @default(true)
  closingDate     DateTime?
  postedAt        DateTime         @default(now())
  sourceUrl       String?
  views           Int              @default(0)
  employerId      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        Category?        @relation(fields: [categoryId], references: [id])
  employer        Employer?        @relation(fields: [employerId], references: [id])
  savedJobs       SavedJob[]
  applications    JobApplication[]
  sponsoredAd     SponsoredAd?
}

model Opportunity {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  type        OpportunityType
  description String?         @db.Text
  providerId  String?
  amount      Float?
  deadline    DateTime?
  link        String?
  isActive    Boolean         @default(true)
  views       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  provider    Employer?       @relation(fields: [providerId], references: [id])
  savedByUsers SavedOpportunity[]
}

model Article {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String   @db.Text
  content    String   @db.LongText
  category   String   @default("Career Advice")
  author     String?
  coverImage String?
  published  Boolean  @default(true)
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  savedByUsers SavedArticle[]
}

model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  preferences String   @default("[]") @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String           @id @default(cuid())
  name          String
  email         String           @unique
  phone         String?
  password      String
  role          UserRole         @default(JOB_SEEKER)
  avatarUrl     String?
  emailVerified DateTime?
  isVerified    Boolean          @default(false)
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  employerId    String?          @unique
  employer      Employer?        @relation(fields: [employerId], references: [id])
  profile       Profile?
  savedJobs     SavedJob[]
  savedOpportunities SavedOpportunity[]
  savedArticles  SavedArticle[]
  applications  JobApplication[]
  jobAlerts     JobAlert[]
  notifications Notification[]
  payments      Payment[]
  cvScans       CVScan[]
  careerDocuments CareerDocument[]
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model SavedOpportunity {
  id             String       @id @default(cuid())
  userId         String
  opportunityId  String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity    Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
}

model SavedArticle {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model JobApplication {
  id             String            @id @default(cuid())
  jobId          String
  userId         String?
  applicantName  String
  applicantEmail String
  applicantPhone String?
  cvUrl          String?
  coverLetter    String?           @db.Text
  status         ApplicationStatus @default(pending)
  appliedAt      DateTime          @default(now())
  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user           User?             @relation(fields: [userId], references: [id])

  @@unique([jobId, applicantEmail])
}

model SponsoredAd {
  id            String             @id @default(cuid())
  jobId         String             @unique
  employerId    String
  package       SponsorshipPackage @default(basic)
  amountPaid    Float?
  paymentStatus PaymentStatus      @default(pending)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime           @default(now())
  job           Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  employer      Employer           @relation(fields: [employerId], references: [id])
}

model Payment {
  id        String         @id @default(cuid())
  userId    String
  serviceId String?
  amount    Float
  mpesaRef  String?
  status    PaymentStatus  @default(pending)
  paidAt    DateTime?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  service   CareerService? @relation(fields: [serviceId], references: [id])
}

model CareerService {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  description  String    @db.Text
  price        Float
  deliveryDays Int       @default(3)
  isActive     Boolean   @default(true)
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  payments     Payment[]
}

enum ExperienceLevel {
  entry
  internship
  casual
  mid
  senior
}

enum OrgType {
  PRIVATE
  SMALL_BUSINESS
  STARTUP
  NGO
  INTERNATIONAL_ORG
  NATIONAL_GOV
  COUNTY_GOV
  STATE_CORPORATION
  EDUCATION
  FOUNDATION
  RELIGIOUS_ORG
}

enum OpportunityType {
  internship
  sponsorship
  bursary
  university_admission
  scholarship
  certification
}

enum UserRole {
  JOB_SEEKER
  EMPLOYER
  ADMIN
}

enum ApplicationStatus {
  pending
  reviewed
  shortlisted
  rejected
}

enum SponsorshipPackage {
  basic
  premium
  featured
}

enum PaymentStatus {
  pending
  paid
  expired
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  title       String?
  summary     String?  @db.Text
  skills      String?  @db.Text
  experience  Json?
  education   Json?
  cvUrl       String?
  cvFileName  String?
  location    String?
  county      String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobAlert {
  id          String         @id @default(cuid())
  userId      String
  keywords    String?
  location    String?
  category    String?
  type        String?
  frequency   AlertFrequency @default(DAILY)
  isActive    Boolean        @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String                @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String                @db.Text
  link      String?
  isRead    Boolean               @default(false)
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AlertFrequency {
  DAILY
  WEEKLY
  INSTANT
}

enum NotificationType {
  APPLICATION_UPDATE
  JOB_ALERT
  SYSTEM
}

model JobUpdate {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String     @db.LongText
  sourceUrl   String?
  sourceName  String     @default("Unknown")
  type        UpdateType @default(GENERAL)
  isPublished Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum UpdateType {
  SHORTLISTED
  INTERVIEW_SCHEDULE
  CLOSING_EXTENDED
  CORRIGENDUM
  GENERAL
}

model CVScan {
  id              String    @id @default(cuid())
  userId          String?
  email           String?
  cvText          String    @db.LongText
  jobDescription  String?   @db.Text
  atsScore        Int       @default(0)
  keywordMatch    Int       @default(0)
  formatScore     Int       @default(0)
  sectionScore    Int       @default(0)
  readabilityScore Int      @default(0)
  skillGaps       Json?
  suggestions     Json?
  improvements    Json?
  issues          Json?
  isAnalyzed      Boolean   @default(false)
  createdAt       DateTime  @default(now())

  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareerDocument {
  id            String          @id @default(cuid())
  userId        String
  type          CareerDocumentType @default(CV)
  title         String
  content       String          @db.LongText
  version       Int             @default(1)
  isPublic      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CareerDocumentType {
  CV
  COVER_LETTER
  LINKEDIN_PROFILE
}
