### 🔹 View: `sitemap_urls`

```sql
CREATE VIEW sitemap_urls AS
    SELECT CONCAT('/job/', slug) as url, updated_at as lastmod, 'weekly' as changefreq, '0.8' as priority
    FROM jobs WHERE is_active = TRUE AND application_deadline >= CURDATE()
    
    UNION ALL
    
    SELECT CONCAT('/jobs/category/', slug), created_at, 'weekly', '0.7'
    FROM categories
    
    UNION ALL
    
    SELECT CONCAT('/jobs/location/', slug), created_at, 'weekly', '0.7'
    FROM locations
    
    UNION ALL
    
    SELECT '/jobs/level/entry', NOW(), 'daily', '0.9'
    UNION ALL
    SELECT '/jobs/level/internship', NOW(), 'daily', '0.9'
    UNION ALL
    SELECT '/jobs/level/casual', NOW(), 'daily', '0.9'
    UNION ALL
    SELECT '/jobs/level/mid', NOW(), 'weekly', '0.7'
    UNION ALL
    SELECT '/jobs/level/senior', NOW(), 'weekly', '0.6'
    
    UNION ALL
    
    SELECT '/jobs/govt/county', NOW(), 'daily', '0.9'
    UNION ALL
    SELECT '/jobs/govt/national', NOW(), 'daily', '0.9'
    
    UNION ALL
    
    SELECT CONCAT('/opportunities/', REPLACE(opportunity_type, '_', '-')), updated_at, 'weekly', '0.8'
    FROM (SELECT DISTINCT opportunity_type FROM opportunities_hub) AS types
    
    UNION ALL
    
    SELECT CONCAT('/opportunities/', slug), updated_at, 'weekly', '0.6'
    FROM opportunities_hub WHERE is_active = TRUE AND deadline >= CURDATE()
    
    UNION ALL
    
    SELECT CONCAT('/blog/', slug), published_at, 'monthly', '0.5'
    FROM blogs WHERE published_at IS NOT NULL;
```

